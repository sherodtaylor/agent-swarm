{
  "mcpServers": {
    "victoria-metrics": {
      "type": "http",
      "url": "http://victoria-metrics-mcp.monitoring.svc.cluster.local:8080/mcp"
    },
    "victoria-logs": {
      "type": "http",
      "url": "http://victoria-logs-mcp.monitoring.svc.cluster.local:8080/mcp"
    },
    "nats": {
      "command": "/usr/local/bin/mcp-nats",
      "args": ["--transport", "stdio"],
      "env": { "NATS_URL": "nats://nats.agent-infra.svc.cluster.local:4222" }
    }
  }
}
