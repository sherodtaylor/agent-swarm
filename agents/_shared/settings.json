{
  "channelsEnabled": true,
  "extraKnownMarketplaces": {
    "claude-code-channel-matrix": {
      "source": { "source": "github", "repo": "zekker6/claude-code-channel-matrix" }
    },
    "claude-plugins-official": {
      "source": { "source": "github", "repo": "anthropics/claude-plugins-official" }
    }
  },
  "enabledPlugins": {
    "matrix@claude-code-channel-matrix": true,
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Verbosity rule: keep your Matrix reply brief. 1-2 sentences for simple responses. Bullets for multi-item info. No filler openers.\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git*)",
      "Bash(gh*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl kustomize*)",
      "Bash(flux*)",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(kubectl delete*)",
      "Bash(git push origin main*)"
    ]
  }
}
