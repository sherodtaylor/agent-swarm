---
import { getCollection } from 'astro:content';
import SpriteDevbot from './SpriteDevbot.astro';
import SpriteInfrabot from './SpriteInfrabot.astro';
import statusData from '../data/crew-status.json';

type SpriteState = 'active' | 'vacation' | 'error';

interface CrewAgent {
  name?: string;
  state?: string;
}

function stateOf(name: string): SpriteState {
  const agents = (statusData.agents ?? []) as CrewAgent[];
  const entry = agents.find((a) => a.name?.toLowerCase() === name.toLowerCase());
  const raw = entry?.state;
  if (raw === 'vacation' || raw === 'error') return raw;
  return 'active';
}

interface Props { limit?: number; }
const { limit = 5 } = Astro.props;

const entries = (await getCollection('log'))
  .sort((a, b) => +new Date(b.data.timestamp) - +new Date(a.data.timestamp))
  .slice(0, limit);
---
<section class="audit-tail" aria-label="Recent log entries">
  <div class="prompt-line">
    <span class="prompt">$</span> tail -f #audit
  </div>
  <ul>
    {entries.map((e, i) => {
      const agentState = stateOf(e.data.agent);
      return (
        <li class:list={[{ 'pulse-new': i === 0 }]}>
          <time datetime={e.data.timestamp.toISOString()}>{e.data.timestamp.toISOString().replace(/\.\d{3}/, '')}</time>
          <span class="agent">
            {e.data.agent === 'devbot'   && <SpriteDevbot   state={agentState} size={16} />}
            {e.data.agent === 'infrabot' && <SpriteInfrabot state={agentState} size={16} />}
            <span class="name">{e.data.agent}</span>
            {agentState === 'vacation' && <span class="dnd-glyph" aria-label="quiet hours">💤</span>}
          </span>
          <span class="kind">{e.data.kind.replace('_', ' ')}</span>
          <span class="run">run={e.data.run_id.slice(0, 6)}</span>
          <span class="summary">{e.data.summary}</span>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .audit-tail   { background: var(--bg-elev); padding: var(--space-6); border-radius: 6px; font-family: var(--font-mono); font-size: var(--fs-mono); }
  .prompt-line  { color: var(--fg-muted); margin-bottom: var(--space-4); }
  .prompt       { color: var(--accent); }
  ul            { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-2); }
  li            { display: grid; grid-template-columns: auto auto auto auto 1fr; gap: var(--space-3); align-items: baseline; }
  time          { color: var(--fg-muted); }
  .agent        { color: var(--fg); display: inline-flex; align-items: center; gap: var(--space-1); }
  .agent .sprite { vertical-align: middle; }
  .dnd-glyph    { color: var(--accent-warn); font-size: 0.85em; }
  .kind         { color: var(--accent-warn); }
  .run          { color: var(--accent); }
  .summary      { color: var(--fg-muted); }
  @media (max-width: 640px) { li { grid-template-columns: 1fr; gap: 0; } }

  /* Newest entry pulses softly in --accent for 1.5s on load. */
  .pulse-new { position: relative; animation: log-pulse 1.5s ease-out 1; }
  .pulse-new::before {
    content: ''; position: absolute; left: calc(var(--space-3) * -1); top: 0;
    bottom: 0; width: 2px; background: var(--accent); opacity: 0;
    animation: log-pulse-bar 1.5s ease-out 1;
  }
  @keyframes log-pulse {
    0%   { background: color-mix(in srgb, var(--accent) 14%, transparent); }
    100% { background: transparent; }
  }
  @keyframes log-pulse-bar {
    0%   { opacity: 0.9; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse-new, .pulse-new::before { animation: none; }
    .pulse-new::before { opacity: 0; }
  }
</style>
