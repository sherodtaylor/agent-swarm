---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TmuxStatusBar from '../../components/TmuxStatusBar.astro';
import SpriteDevbot from '../../components/SpriteDevbot.astro';
import SpriteInfrabot from '../../components/SpriteInfrabot.astro';
import statusData from '../../data/crew-status.json';

type SpriteState = 'active' | 'vacation' | 'error';

interface CrewAgent {
  name?: string;
  state?: string;
}

function stateOf(name: string): SpriteState {
  const agents = (statusData.agents ?? []) as CrewAgent[];
  const entry = agents.find((a) => a.name?.toLowerCase() === name.toLowerCase());
  const raw = entry?.state;
  if (raw === 'vacation' || raw === 'error') return raw;
  return 'active';
}

const entries = (await getCollection('log'))
  .sort((a, b) => +b.data.timestamp - +a.data.timestamp);

// Pre-render each entry so we can show the MDX body inside <details>.
const rendered = await Promise.all(
  entries.map(async (e) => ({ entry: e, Content: (await e.render()).Content }))
);
---
<BaseLayout title="Log">
  <TmuxStatusBar slot="status-bar" sessionName="0:log" />
  <h1>$ tail -f #audit</h1>
  <p class="measure" style="color: var(--fg-muted);">
    Reverse-chronological record of notable agent actions. One line per
    event; expand for context.
  </p>
  <ul class="log-feed">
    {rendered.map(({ entry: e, Content }, i) => {
      const agentState = stateOf(e.data.agent);
      return (
        <li class:list={[{ 'pulse-new': i === 0 }]}>
          <details>
            <summary>
              <time datetime={e.data.timestamp.toISOString()}>{e.data.timestamp.toISOString().replace(/\.\d{3}/, '')}</time>{' '}
              <span class="agent">
                {e.data.agent === 'devbot'   && <SpriteDevbot   state={agentState} size={16} />}
                {e.data.agent === 'infrabot' && <SpriteInfrabot state={agentState} size={16} />}
                <span class="name">{e.data.agent}</span>
                {agentState === 'vacation' && <span class="dnd-glyph" aria-label="quiet hours">💤</span>}
              </span>{' '}
              <span class="kind">{e.data.kind.replace('_', ' ')}</span>{' '}
              <span class="run">run={e.data.run_id.slice(0, 6)}</span>{' '}
              <span class="summary">{e.data.summary}</span>
              {e.data.link && <a href={e.data.link} class="link">[link]</a>}
            </summary>
            <div class="body">
              <Content />
            </div>
          </details>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  .log-feed   { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-2); font-family: var(--font-mono); font-size: var(--fs-mono); }
  .log-feed time    { color: var(--fg-muted); }
  .log-feed .agent  { color: var(--fg); display: inline-flex; align-items: center; gap: var(--space-1); }
  .log-feed .agent .sprite { vertical-align: middle; }
  .log-feed .dnd-glyph { color: var(--accent-warn); font-size: 0.85em; }
  .log-feed .kind   { color: var(--accent-warn); }
  .log-feed .run    { color: var(--accent); }
  .log-feed .summary{ color: var(--fg-muted); }
  .log-feed .link   { margin-left: var(--space-2); color: var(--accent); }
  details summary   { cursor: pointer; padding: var(--space-2); }
  details[open] summary { background: var(--bg-elev); border-radius: 4px; }
  details .body     { padding: var(--space-4) var(--space-6); color: var(--fg); font-family: var(--font-body); font-size: var(--fs-body); }
  details .body p:first-child { margin-top: 0; }

  /* Newest entry pulses softly in --accent for 1.5s on load. */
  .pulse-new { position: relative; animation: log-pulse 1.5s ease-out 1; border-radius: 4px; }
  .pulse-new::before {
    content: ''; position: absolute; left: -6px; top: 4px; bottom: 4px;
    width: 2px; background: var(--accent); opacity: 0;
    animation: log-pulse-bar 1.5s ease-out 1;
  }
  @keyframes log-pulse {
    0%   { background: color-mix(in srgb, var(--accent) 14%, transparent); }
    100% { background: transparent; }
  }
  @keyframes log-pulse-bar {
    0%   { opacity: 0.9; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse-new, .pulse-new::before { animation: none; }
    .pulse-new::before { opacity: 0; }
  }
</style>
